discovery.group set — STEADYBIT_EXTENSION_DISCOVERY_GROUP is added:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      name: extensionlib-test
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: extensionlib-test
      template:
        metadata:
          labels:
            app: extensionlib-test
        spec:
          containers:
            - env:
                - name: STEADYBIT_LOG_LEVEL
                  value: INFO
                - name: STEADYBIT_LOG_FORMAT
                  value: text
                - name: STEADYBIT_EXTENSION_DISCOVERY_GROUP
                  value: prod-eu
              image: test:latest
              name: extension
              volumeMounts: null
          volumes: null
