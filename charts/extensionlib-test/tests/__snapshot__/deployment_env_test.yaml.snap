client TLS CAs from paths:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      name: extensionlib-test
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: extensionlib-test
      template:
        metadata:
          labels:
            app: extensionlib-test
        spec:
          containers:
            - env:
                - name: STEADYBIT_LOG_LEVEL
                  value: INFO
                - name: STEADYBIT_LOG_FORMAT
                  value: text
                - name: STEADYBIT_EXTENSION_TLS_CLIENT_CAS
                  value: /etc/ca-one.crt,/etc/ca-two.crt
              image: test:latest
              name: extension
              volumeMounts: null
          volumes: null
client TLS CAs from secrets:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      name: extensionlib-test
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: extensionlib-test
      template:
        metadata:
          labels:
            app: extensionlib-test
        spec:
          containers:
            - env:
                - name: STEADYBIT_LOG_LEVEL
                  value: INFO
                - name: STEADYBIT_LOG_FORMAT
                  value: text
                - name: STEADYBIT_EXTENSION_TLS_CLIENT_CAS
                  value: /etc/extension/certificates/ca-one/tls.crt,/etc/extension/certificates/ca-two/tls.crt
              image: test:latest
              name: extension
              volumeMounts:
                - mountPath: /etc/extension/certificates/ca-one
                  name: certificate-ca-one
                  readOnly: true
                - mountPath: /etc/extension/certificates/ca-two
                  name: certificate-ca-two
                  readOnly: true
          volumes:
            - name: certificate-ca-one
              secret:
                optional: false
                secretName: ca-one
            - name: certificate-ca-two
              secret:
                optional: false
                secretName: ca-two
custom log level and format:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      name: extensionlib-test
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: extensionlib-test
      template:
        metadata:
          labels:
            app: extensionlib-test
        spec:
          containers:
            - env:
                - name: STEADYBIT_LOG_LEVEL
                  value: debug
                - name: STEADYBIT_LOG_FORMAT
                  value: json
              image: test:latest
              name: extension
              volumeMounts: null
          volumes: null
