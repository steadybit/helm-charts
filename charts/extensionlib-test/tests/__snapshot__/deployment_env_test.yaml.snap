server TLS from path:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      name: extensionlib-test
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: extensionlib-test
      template:
        metadata:
          labels:
            app: extensionlib-test
        spec:
          containers:
            - env:
                - name: STEADYBIT_LOG_LEVEL
                  value: INFO
                - name: STEADYBIT_LOG_FORMAT
                  value: text
                - name: STEADYBIT_EXTENSION_TLS_SERVER_CERT
                  value: /etc/ext/tls.crt
                - name: STEADYBIT_EXTENSION_TLS_SERVER_KEY
                  value: /etc/ext/tls.key
              image: test:latest
              name: extension
              volumeMounts: null
          volumes: null
server TLS from secret:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      name: extensionlib-test
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: extensionlib-test
      template:
        metadata:
          labels:
            app: extensionlib-test
        spec:
          containers:
            - env:
                - name: STEADYBIT_LOG_LEVEL
                  value: INFO
                - name: STEADYBIT_LOG_FORMAT
                  value: text
                - name: STEADYBIT_EXTENSION_TLS_SERVER_CERT
                  value: /etc/extension/certificates/server-tls/tls.crt
                - name: STEADYBIT_EXTENSION_TLS_SERVER_KEY
                  value: /etc/extension/certificates/server-tls/tls.key
                - name: STEADYBIT_EXTENSION_DISCOVERY_GROUP
                  value: g1
              image: test:latest
              name: extension
              volumeMounts:
                - mountPath: /etc/extension/certificates/server-tls
                  name: certificate-server-tls
                  readOnly: true
          volumes:
            - name: certificate-server-tls
              secret:
                optional: false
                secretName: server-tls
