should allow per-route hostnames and annotations:
  1: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      annotations:
        example.com/ws: "true"
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: steadybit-platform
        app.kubernetes.io/version: 0.0.0
        helm.sh/chart: steadybit-platform-0.0.0
      name: RELEASE-NAME-steadybit-platform-ws
      namespace: NAMESPACE
    spec:
      hostnames:
        - ws.steadybit.example.com
      parentRefs:
        - name: my-gateway
      rules:
        - backendRefs:
            - name: RELEASE-NAME-steadybit-platform
              port: 7878
          matches:
            - path:
                type: PathPrefix
                value: /ws
  2: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      annotations:
        example.com/ui: "true"
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: steadybit-platform
        app.kubernetes.io/version: 0.0.0
        helm.sh/chart: steadybit-platform-0.0.0
      name: RELEASE-NAME-steadybit-platform
      namespace: NAMESPACE
    spec:
      hostnames:
        - ui.steadybit.example.com
      parentRefs:
        - name: my-gateway
      rules:
        - backendRefs:
            - name: RELEASE-NAME-steadybit-platform
              port: 80
          matches:
            - path:
                type: PathPrefix
                value: /
should allow per-route parentRefs for split ALB:
  1: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: steadybit-platform
        app.kubernetes.io/version: 0.0.0
        helm.sh/chart: steadybit-platform-0.0.0
      name: RELEASE-NAME-steadybit-platform-ws
      namespace: NAMESPACE
    spec:
      hostnames:
        - platform.steadybit.example.com
      parentRefs:
        - name: internal-gateway
          namespace: gateway-ns
      rules:
        - backendRefs:
            - name: RELEASE-NAME-steadybit-platform
              port: 7878
          matches:
            - path:
                type: PathPrefix
                value: /ws
  2: |
    apiVersion: gateway.networking.k8s.io/v1
    kind: HTTPRoute
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: steadybit-platform
        app.kubernetes.io/version: 0.0.0
        helm.sh/chart: steadybit-platform-0.0.0
      name: RELEASE-NAME-steadybit-platform
      namespace: NAMESPACE
    spec:
      hostnames:
        - platform.steadybit.example.com
      parentRefs:
        - name: external-gateway
          namespace: gateway-ns
      rules:
        - backendRefs:
            - name: RELEASE-NAME-steadybit-platform
              port: 80
          matches:
            - path:
                type: PathPrefix
                value: /
